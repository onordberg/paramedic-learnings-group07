DATABASE_URL=postgresql://postgres:postgres@localhost:15432/paramedic_learnings

# Authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=replace_with_generated_secret
# Azure OpenAI — resource name is the subdomain of your endpoint URL
# e.g. https://<AZURE_RESOURCE_NAME>.openai.azure.com/
AZURE_API_KEY=your_azure_openai_api_key_here
AZURE_RESOURCE_NAME=your_resource_name_here
AZURE_DEPLOYMENT_NAME=your_deployment_name_here
